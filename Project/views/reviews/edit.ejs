<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Edit Your Review</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-dark">
<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow">
                <div class="card-header bg-warning text-dark">
                    <h4 class="mb-0">Edit Review</h4>
                </div>
                <div class="card-body">

                    <% if (locals.errors && errors.length > 0) { %>
                        <div class="alert alert-danger">
                            <% errors.forEach(error => { %>
                                <div><%= error.msg %></div>
                            <% }) %>
                        </div>
                    <% } %>

                    <form action="/movies/<%= movieId %>/reviews/<%= review._id %>/update" method="POST">
                        
                        <div class="mb-3">
                            <label class="form-label">Rating (1-10)</label>
                            <input type="number" name="rating" class="form-control" min="1" max="10" value="<%= review ? review.rating : '' %>" required>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Your Review</label>
                            <textarea name="comment" rows="5" class="form-control" required><%= review ? review.comment : '' %></textarea>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary">Save Changes</button>
                            <a href="/details?id=<%= movieId %>" class="btn btn-outline-secondary">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
</body>
</html>