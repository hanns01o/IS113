<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <link rel="stylesheet" href="/movieDetails.css">
    <link rel="stylesheet" href="/header.css">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        .backdrop {
            padding: 50px 25px;
            background-image: url("https://image.tmdb.org/t/p/w1280<%= movie.backdrop_path %>");
            background-size: cover;
            background-position: center top;
            inset: 0;
            width: 100%;
        }
    </style>
</head>

<body class="bg-dark text-white">
    <%- include("partials/header") %>
        <div class="back-row">
            <a href="javascript:history.back()" class="back-btn">← Back</a>
        </div>
        <div class="backdrop">
            <table>
                <tr>
                    <td rowspan="4"><img src="https://image.tmdb.org/t/p/w500<%= movie.poster_path %>"
                            alt="<%= movie.title %>" /></td>
                    <td>
                        <h1>
                            <%=movie.title%>
                        </h1>
                    </td>
                </tr>
                <tr>
                    <td>
                        <% for(genre of movie.genres){ %>
                            <a href="/genre?tag=<%=genre.id%>">
                                <%=genre.name%>
                            </a> &nbsp;
                            <% } %>
                    </td>
                </tr>
                <tr>
                    <td>
                        <% 
                        let totalScore=movie.vote_average; 
                        let totalCount=1; 

                        if (reviews && reviews.length> 0) {
                            const userTotal = reviews.reduce((sum, r) => sum + r.rating, 0);
                            totalScore += userTotal;
                            totalCount += reviews.length;
                            }

                            
                        let combinedRating = (totalScore / totalCount).toFixed(1);
                        %>

                            <span style="color: #ffc107; font-size: 1.2rem;">★</span>
                            <strong style="font-size: 1.2rem;">
                                <%= combinedRating %>
                            </strong>/10

                            <div class="text-secondary" style="font-size: 0.85rem; margin-top: 4px;">
                                Based on Official Rating + <%= reviews.length %> User Reviews
                            </div>
                    </td>
                </tr>
                <tr>
                    <td>
                        <p>
                            <%=movie.overview%>
                        </p>

                        <% if (inWatchlist) { %>
                            <form method="POST" action="/watchlist/remove/<%= movie.id %>">
                                <button type="submit" class="watchlist-btn remove">Remove from Watchlist</button>
                            </form>
                            <% if (!watchedStatus) { %>
                                <form method="POST" action="/watchlist/updateadd/<%= movie.id %>">
                                    <button type="submit" class="watchlist-btn">Mark as Watched</button>
                                </form>
                                <% } else { %>
                                    <form method="POST" action="/watchlist/updateremove/<%= movie.id %>">
                                        <button type="submit" class="watchlist-btn remove">Mark as Unwatched</button>
                                    </form>
                                    <% } %>
                                        <% } else { %>
                                            <form method="POST" action="/watchlist/add/<%= movie.id %>">
                                                <input type="hidden" name="movieTitle" value="<%= movie.title %>">
                                                <input type="hidden" name="posterPath" value="<%= movie.poster_path %>">
                                                <button type="submit" class="watchlist-btn">Add to Watchlist</button>
                                            </form>
                                            <% } %>
                    </td>
                </tr>
            </table>
        </div>
        <div class="container">
            <% if (locals.errors && errors.length> 0) { %>
                <div class="alert alert-danger shadow-sm"
                    style="background-color: #f8d7da; color: #721c24; padding: 15px; border-radius: 8px; margin-bottom: 20px; border-left: 5px solid #dc3545;">
                    <ul style="margin: 0; padding-left: 20px;">
                        <% errors.forEach(error=> { %>
                            <li><strong>Error:</strong>
                                <%= error.msg %>
                            </li>
                            <% }) %>
                    </ul>
                </div>
                <% } %>
        </div>
        <br><br>
        <h2>Reviews</h2>
        <div class="container mt-5">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <% if (currentUser && currentUser.userId && currentUser.role !=='admin' ) { %>
                    <a href="/movies/<%= movieId %>/reviews/new" class="btn btn-primary">+ Write a Review</a>
                    <% } else if (currentUser && currentUser.role==='admin' ) { %>
                        <div class="alert alert-info">Admin mode: Viewing Only</div>
                        <% } else { %>
                            <a href="/login" class="btn btn-outline-secondary">Login to write a review</a>
                            <% } %>
            </div>

            <hr>
            <% if (reviews && reviews.length> 0) { %>
                <% reviews.forEach(review=> { %>
                    <div class="card review-card shadow-sm">
                        <div class="card-body">
                            <div class="d-flex justify-content-between">
                                <h5 class="card-title">
                                    <u><b>A Review By @<%= review.user.username %></b></u>
                                </h5>
                                <span class="badge bg-dark text-light rating-badge">
                                    ⭐ <%= review.rating %>/10
                                </span>
                            </div>

                            <p class="card-text mt-2 text-muted italic">"<%= review.comment %>"</p>

                            <small class="text-secondary">
                                Posted on: <%= new Date(review.createdAt).toLocaleDateString() %>
                                    <% if (review.updatedAt.getTime()> review.createdAt.getTime()) { %>
                                        <span class="ms-2 text-info">
                                            (Edited: <%= new Date(review.updatedAt).toLocaleDateString() %>)
                                        </span>
                                        <% } %>
                            </small>

                            <% if (currentUser && currentUser.userId && review.user &&
                                review.user._id.toString()===currentUser.userId.toString()) { %>
                                <div class="mt-3 d-flex gap-2">
                                    <a href="/movies/<%= movieId %>/reviews/<%= review._id %>/update"
                                        class="btn btn-sm btn-outline-secondary">Edit</a>

                                    <form action="/movies/<%= movieId %>/reviews/<%= review._id %>/delete" method="POST"
                                        onsubmit="return confirm('Delete this review?')">
                                        <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                                    </form>
                                </div>
                                <% } %>

                                    <% if (currentUser && currentUser.userId && review.user &&
                                        review.user._id.toString() !==currentUser.userId.toString()) { %>
                                        <div class="mt-3">
                                            <button class="report-btn"
                                                onclick="openReportModal('<%= review._id %>')">Report</button>
                                        </div>
                                        <% } %>
                        </div>
                    </div>
                    <% }) %>
                        <% } else { %>
                            <div class="alert alert-info">No reviews yet. Be the first to write one!</div>
                            <% } %>
                                <!-- 
                                <div class="mt-4">
                                    <a href="/movies" class="btn btn-link">← Back to Watchlist</a>
                                </div> -->


        </div>

        <div id="reportOverlay" style="display:none; position:fixed; top:0; left:0;
    width:100%; height:100%; background:rgba(0,0,0,0.6); z-index:999;" onclick="closeReportModal()">
        </div>

        <!-- Report form popup -->
        <div id="reportModal" style="display:none; position:fixed; top:50%; left:50%;
    transform:translate(-50%,-50%); background:#13131a; border:1px solid #1e1e28;
    border-radius:10px; padding:24px; width:360px; z-index:1000;">

            <h3 style="font-family:'Bebas Neue',sans-serif; font-size:22px;
        letter-spacing:1.5px; color:#f0ede6; margin-bottom:16px;">
                Report Review
            </h3>

            <form id="reportForm" method="POST" action="">
                <input type="hidden" name="backUrl" value="/details?id=<%= movie.id %>">

                <p style="color:#6b6878; font-size:13px; margin-bottom:12px;">
                    Why are you reporting this?
                </p>

                <label style="display:block; padding:8px 0; color:#f0ede6; font-size:14px; cursor:pointer;">
                    <input type="radio" name="reason" value="spam" required> Spam or fake review
                </label>
                <label style="display:block; padding:8px 0; color:#f0ede6; font-size:14px; cursor:pointer;">
                    <input type="radio" name="reason" value="spoilers"> Contains spoilers
                </label>
                <label style="display:block; padding:8px 0; color:#f0ede6; font-size:14px; cursor:pointer;">
                    <input type="radio" name="reason" value="offensive"> Offensive language
                </label>
                <label style="display:block; padding:8px 0; color:#f0ede6; font-size:14px; cursor:pointer;">
                    <input type="radio" name="reason" value="harassment"> Harassment
                </label>
                <label style="display:block; padding:8px 0; color:#f0ede6; font-size:14px; cursor:pointer;">
                    <input type="radio" name="reason" value="other"> Other
                </label>

                <textarea name="details" placeholder="Any extra details (optional)" maxlength="300" rows="2" style="width:100%; margin-top:12px; padding:8px; background:#0a0a0f;
            border:1px solid #1e1e28; border-radius:6px; color:#f0ede6;
            font-size:13px; resize:none;"></textarea>

                <div style="display:flex; gap:10px; margin-top:16px;">
                    <button type="button" onclick="closeReportModal()" style="flex:1; padding:10px; border-radius:6px; border:1px solid #6b6878;
                background:transparent; color:#6b6878; cursor:pointer; font-size:13px;">
                        Cancel
                    </button>
                    <button type="submit" style="flex:1; padding:10px; border-radius:6px; border:1px solid #ef4444;
                background:#ef4444; color:white; cursor:pointer; font-size:13px;">
                        Submit Report
                    </button>
                </div>
            </form>
        </div>

        <script>
            function openReportModal(reviewId) {
                document.getElementById("reportForm").action = "/reviews/" + reviewId + "/report";
                document.getElementById("reportOverlay").style.display = "block";
                document.getElementById("reportModal").style.display = "block";
            }

            function closeReportModal() {
                document.getElementById("reportOverlay").style.display = "none";
                document.getElementById("reportModal").style.display = "none";
                document.getElementById("reportForm").reset();
            }
        </script>

</body>

</html>