<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <link rel="stylesheet" href="/movieDetails.css">
    <link rel="stylesheet" href="/header.css">
    <style>
        .backdrop {
            padding: 50px 25px;
            background-image: url("https://image.tmdb.org/t/p/w1280<%= movie.backdrop_path %>");
            background-size: cover;
            background-position: center top;
            inset: 0;
            width: 100%;
        }
    </style>
</head>

<body>
    <%- include("partials/header") %>
    <div class="back-row">
        <a href="javascript:history.back()" class="back-btn">← Back</a>
    </div>
        <div class="backdrop">
            <table>
                <tr>
                    <td rowspan="4"><img src="https://image.tmdb.org/t/p/w500<%= movie.poster_path %>"
                            alt="<%= movie.title %>" /></td>
                    <td>
                        <h1>
                            <%=movie.title%>
                        </h1>
                    </td>
                </tr>
                <tr>
                    <td>
                        <% for(genre of movie.genres){ %>
                            <a href="/genre?tag=<%=genre.id%>">
                                <%=genre.name%>
                            </a> &nbsp;
                            <% } %>
                    </td>
                </tr>
                <tr>
                    <td>
                        <%=movie.vote_average.toFixed(1)%>/10
                    </td>
                </tr>
                <tr>
                    <td>
                        <p>
                            <%=movie.overview%>
                        </p>

                        <% if (inWatchlist) { %>
                            <form method="POST" action="/watchlist/remove/<%= movie.id %>">
                                <button type="submit" class="watchlist-btn remove">Remove from Watchlist</button>
                            </form>
                            <% if (!watchedStatus) { %>
                                <form method="POST" action="/watchlist/updateadd/<%= movie.id %>">
                                    <button type="submit" class="watchlist-btn">Mark as Watched</button>
                                </form>
                                <% } else { %>
                                    <form method="POST" action="/watchlist/updateremove/<%= movie.id %>">
                                        <button type="submit" class="watchlist-btn remove">Mark as Unwatched</button>
                                    </form>
                                    <% } %>
                                        <% } else { %>
                                            <form method="POST" action="/watchlist/add/<%= movie.id %>">
                                                <input type="hidden" name="movieTitle" value="<%= movie.title %>">
                                                <input type="hidden" name="posterPath" value="<%= movie.poster_path %>">
                                                <button type="submit" class="watchlist-btn">Add to Watchlist</button>
                                            </form>
                                            <% } %>
                    </td>
                </tr>
            </table>
        </div>
        <h2>Reviews</h2>
        <div class="container mt-5">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <% if (currentUser && currentUser.userId) { %>
                    <a href="/movies/<%= movieId %>/reviews/new" class="btn btn-primary">+ Write a Review</a>
                    <% } else { %>
                        <a href="/login" class="btn btn-outline-secondary">Login to write a review</a>
                        <% } %>
            </div>

            <hr>
            <% if (reviews && reviews.length> 0) { %>
                <% reviews.forEach(review=> { %>
                    <div class="card review-card shadow-sm">
                        <div class="card-body">
                            <div class="d-flex justify-content-between">
                                <h5 class="card-title">
                                    <u><b>A Review By @<%= review.user.username %></b></u>
                                </h5>
                                <span class="badge bg-dark text-light rating-badge">
                                    ⭐ <%= review.rating %>/10
                                </span>
                            </div>

                            <p class="card-text mt-2 text-muted italic">"<%= review.comment %>"</p>

                            <small class="text-secondary">
                                Posted on: <%= new Date(review.createdAt).toLocaleDateString() %>
                                    <% if (review.updatedAt.getTime()> review.createdAt.getTime()) { %>
                                        <span class="ms-2 text-info">
                                            (Edited: <%= new Date(review.updatedAt).toLocaleDateString() %>)
                                        </span>
                                        <% } %>
                            </small>

                            <% if (currentUser && currentUser.userId && review.user &&
                                review.user._id.toString()===currentUser.userId.toString()) { %>
                                <div class="mt-3 d-flex gap-2">
                                    <a href="/movies/<%= movieId %>/reviews/<%= review._id %>/update"
                                        class="btn btn-sm btn-outline-secondary">Edit</a>

                                    <form action="/movies/<%= movieId %>/reviews/<%= review._id %>/delete" method="POST"
                                        onsubmit="return confirm('Delete this review?')">
                                        <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                                    </form>
                                </div>
                                <% } %>
                        </div>
                    </div>
                    <% }) %>
                        <% } else { %>
                            <div class="alert alert-info">No reviews yet. Be the first to write one!</div>
                            <% } %>

                                <div class="mt-4">
                                    <a href="/movies" class="btn btn-link">← Back to Watchlist</a>
                                </div>
        </div>

</body>

</html>