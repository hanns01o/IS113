<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/header.css">
    <style>
        :root {
            --bg: #0a0a0f;
            --surface: #13131a;
            --accent: #e8c84a;
            --text: #f0ede6;
            --muted: #6b6878;
            --border: #1e1e28;
            --radius: 10px;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            background-color: var(--bg);
            color: var(--text);
            font-family: 'DM Sans', sans-serif;
            min-height: 100vh;
            padding: 40px;
            position: relative;
            /* ← add this */

        }

        .backdrop {
            margin: 40px 0px 0px 0px;
            padding: 50px 25px;
            background-image: url("https://image.tmdb.org/t/p/w1280<%= movie.backdrop_path %>");
            background-size: cover;
            background-position: center top;
            inset: 0;
            width: 100%;
        }

        /* ── Back link ── */
        .back {
            display: inline-block;
            font-family: 'Bebas Neue', sans-serif;
            letter-spacing: 1.5px;
            font-size: 15px;
            color: var(--muted);
            text-decoration: none;
            margin-bottom: 36px;
            transition: color 0.2s;
        }

        .back:hover {
            color: var(--accent);
        }

        /* ── Detail table ── */
        table {
            background: var(--surface);
            overflow: hidden;
            max-width: 860px;
        }

        table a {
            color: #f0ede6;
            text-decoration: none;
        }

        table a:hover {
            color: #e8c84a;
        }

        /* Poster cell */
        td:first-child {
            vertical-align: top;
            padding: 0;
        }

        td:first-child img {
            display: block;
            width: 300px;
            height: 100%;
            object-fit: cover;
        }

        /* Info cells */
        td:last-child {
            padding: 24px 32px;
            vertical-align: top;
            border-left: 1px solid var(--border);
        }

        tr+tr td:last-child {
            border-top: 1px solid var(--border);
        }

        /* Title */
        h1 {
            font-family: 'Bebas Neue', sans-serif;
            font-size: 42px;
            letter-spacing: 2px;
            color: var(--text);
            line-height: 1;
        }

        /* Genre tags */
        .genre-link {
            display: inline-block;
            font-size: 12px;
            font-weight: 500;
            color: var(--accent);
            text-decoration: none;
            border: 1px solid var(--accent);
            border-radius: 40px;
            padding: 4px 12px;
            margin-right: 6px;
            transition: all 0.2s ease;
        }

        .genre-link:hover {
            background: var(--accent);
            color: var(--bg);
        }

        /* Rating */
        .rating {
            font-family: 'Bebas Neue', sans-serif;
            font-size: 28px;
            letter-spacing: 1px;
            color: var(--accent);
        }

        .rating span {
            color: var(--muted);
            font-size: 18px;
        }

        /* Overview */
        p {
            font-size: 15px;
            line-height: 1.75;
            color: #b0adb8;
            max-width: 480px;
        }

        /* ── Reviews heading ── */
        h2 {
            font-family: 'Bebas Neue', sans-serif;
            font-size: 28px;
            letter-spacing: 2px;
            color: var(--text);
            margin-top: 48px;
            max-width: 860px;
            padding-bottom: 12px;
            border-bottom: 1px solid var(--border);
        }

        .watchlist-btn {
            margin-top: 16px;
            padding: 12px 18px;
            border-radius: 999px;
            border: 1px solid var(--accent);
            background: transparent;
            color: var(--accent);
            font-family: 'Bebas Neue', sans-serif;
            letter-spacing: 1.5px;
            font-size: 14px;
            cursor: pointer;
            transition: all 0.25s ease;
        }

        /* Hover effect */
        .watchlist-btn:hover {
            background: var(--accent);
            color: var(--bg);
        }

        /* Optional: different style for REMOVE */
        .watchlist-btn.remove {
            border-color: #ef4444;
            color: #ef4444;
        }

        .watchlist-btn.remove:hover {
            background: #ef4444;
            color: white;
        }
    </style>
</head>

<body>
    <%- include("partials/header") %>
        <div class="backdrop">
            <table>
                <tr>
                    <td rowspan="5"><img src="https://image.tmdb.org/t/p/w500<%= movie.poster_path %>"
                            alt="<%= movie.title %>" width="300px" /></td>
                    <td>
                        <h1>
                            <%=movie.title%>
                        </h1>
                    </td>
                </tr>
                <tr>
                    <td>
                        <% for(genre of movie.genres){ %>
                            <a href="/genre?tag=<%=genre.id%>">
                                <%=genre.name%>
                            </a> &nbsp;
                            <% } %>
                    </td>
                </tr>
                <tr>
                    <td>
                        <%=movie.vote_average.toFixed(1)%>/10
                    </td>
                </tr>
                <tr>
                    <td>
                        <p>
                            <%=movie.overview%>
                        </p>

                        <% if (inWatchlist) { %>
                            <form method="POST" action="/watchlist/remove/<%= movie.id %>">
                                <button type="submit" class="watchlist-btn remove">Remove from Watchlist</button>
                            </form>
                            <% if (!watchedStatus) { %>
                                <form method="POST" action="/watchlist/updateadd/<%= movie.id %>">
                                    <button type="submit" class="watchlist-btn">Mark as Watched</button>
                                </form>
                                <% } else { %>
                                    <form method="POST" action="/watchlist/updateremove/<%= movie.id %>">
                                        <button type="submit" class="watchlist-btn remove">Mark as Unwatched</button>
                                    </form>
                                    <% } %>
                                        <% } else { %>
                                            <form method="POST" action="/watchlist/add/<%= movie.id %>">
                                                <input type="hidden" name="movieTitle" value="<%= movie.title %>">
                                                <input type="hidden" name="posterPath" value="<%= movie.poster_path %>">
                                                <button type="submit" class="watchlist-btn">Add to Watchlist</button>
                                            </form>
                                            <% } %>
                    </td>
                </tr>
            </table>
        </div>
        <h2>Reviews</h2>
        <div class="container mt-5">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <% if (currentUser && currentUser.userId) { %>
                <a href="/movies/<%= movieId %>/reviews/new" class="btn btn-primary">+ Write a Review</a>
                <% } else { %>
                <a href="/login" class="btn btn-outline-secondary">Login to write a review</a>
                <% } %>
            </div>

            <hr>
            <% if (reviews && reviews.length> 0) { %>
                <% reviews.forEach(review=> { %>
                    <div class="card review-card shadow-sm">
                        <div class="card-body">
                            <div class="d-flex justify-content-between">
                                <h5 class="card-title">
                                    <u><b>A Review By @<%= review.user.username %></b></u>
                                </h5>
                                <span class="badge bg-dark text-light rating-badge">
                                    ⭐ <%= review.rating %>/10
                                </span>
                            </div>

                            <p class="card-text mt-2 text-muted italic">"<%= review.comment %>"</p>

                            <small class="text-secondary">
                                Posted on: <%= new Date(review.createdAt).toLocaleDateString() %>
                                    <% if (review.updatedAt.getTime() > review.createdAt.getTime()) { %>
                                        <span class="ms-2 text-info">
                                        (Edited: <%= new Date(review.updatedAt).toLocaleDateString() %>)
                                        </span>        
                                    <% } %>
                            </small>

                            <% if (currentUser && currentUser.userId && review.user && review.user._id.toString() === currentUser.userId.toString()) { %>
                                <div class="mt-3 d-flex gap-2">
                                    <a href="/movies/<%= movieId %>/reviews/<%= review._id %>/update"
                                        class="btn btn-sm btn-outline-secondary">Edit</a>

                                    <form action="/movies/<%= movieId %>/reviews/<%= review._id %>/delete" method="POST"
                                        onsubmit="return confirm('Delete this review?')">
                                        <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                                    </form>
                                </div>
                                <% } %>
                        </div>
                    </div>
                    <% }) %>
                        <% } else { %>
                            <div class="alert alert-info">No reviews yet. Be the first to write one!</div>
                            <% } %>

                                <div class="mt-4">
                                    <a href="/movies" class="btn btn-link">← Back to Watchlist</a>
                                </div>
        </div>

</body>

</html>