<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>MovieHub | Home</title>
  <link rel="stylesheet" href="/header.css">
  <link rel="stylesheet" href="/home.css">
</head>
<body>
  <%- include("partials/header") %>

  <% if (featuredMovies && featuredMovies.length > 0) { %>
    <section class="hero-slider page-with-header">
      <% featuredMovies.forEach((movie, index) => { %>
        <div
          class="hero-slide <%= index === 0 ? 'active' : '' %>"
          style="background-image: linear-gradient(to right, rgba(0,0,0,0.88), rgba(0,0,0,0.25)), url('<%= movie.backdropUrl %>');"
        >
          <div class="hero-content">
            <h1><%= movie.title %></h1>
            <p class="hero-meta">
              ⭐ <%= movie.rating.toFixed(1) %> &nbsp; | &nbsp; <%= movie.releaseDate %>
            </p>
            <p class="description">
              <%= movie.overview ? movie.overview.substring(0, 180) + "..." : "No description available." %>
            </p>

            <div class="hero-buttons">
              <a href="/details?id=<%= movie.id %>" class="primary-btn">View Details</a>
              <a href="/movies" class="secondary-btn">Browse Movies</a>
            </div>
          </div>
        </div>
      <% }) %>

      <div class="hero-indicators">
        <% featuredMovies.forEach((movie, index) => { %>
          <button class="indicator <%= index === 0 ? 'active' : '' %>" data-index="<%= index %>"></button>
        <% }) %>
      </div>
    </section>
  <% } else { %>
    <section class="hero empty-hero page-with-header">
      <div class="hero-content">
        <h1>Welcome to MovieHub</h1>
        <p class="description">Start adding movies to your watchlist to personalize your homepage.</p>
        <div class="hero-buttons">
          <a href="/movies" class="primary-btn">Browse Movies</a>
        </div>
      </div>
    </section>
  <% } %>

  <% if (currentUser && currentUser.userId) { %>
    <main class="content-section">
      <section class="movie-row-section">
        <div class="section-header">
          <h2>My Watchlist</h2>
          <a href="/watchlist" class="see-more-btn">See More</a>
        </div>

        <% if (watchlistMovies.length > 0) { %>
          <div class="movie-row">
            <% watchlistMovies.forEach(movie => { %>
              <a href="/details?id=<%= movie._id %>" class="movie-card">
                <img src="<%= movie.posterUrl %>" alt="<%= movie.title %>">
                <div class="movie-overlay">
                  <h3><%= movie.title %></h3>
                  <p><%= movie.genre %></p>
                </div>
              </a>
            <% }) %>
          </div>
        <% } else { %>
          <p class="empty-text">Your watchlist is empty. Add some 
            <a href="/movies">movies</a> to see them here.</p>
        <% } %>
      </section>

      <section>
        <div>
          <h2>You Might Also Like</h2>
        </div>
      </section>
    </main>
  <% } %>

  <script>
    const slides = document.querySelectorAll(".hero-slide");
    const indicators = document.querySelectorAll(".indicator");
    let currentIndex = 0;

    function showSlide(index) {
      slides.forEach((slide, i) => {
        slide.classList.toggle("active", i === index);
      });

      indicators.forEach((dot, i) => {
        dot.classList.toggle("active", i === index);
      });

      currentIndex = index;
    }

    if (slides.length > 0) {
      setInterval(() => {
        const nextIndex = (currentIndex + 1) % slides.length;
        showSlide(nextIndex);
      }, 4000);
    }

    indicators.forEach(dot => {
      dot.addEventListener("click", () => {
        const index = Number(dot.dataset.index);
        showSlide(index);
      });
    });
  </script>
</body>
</html>