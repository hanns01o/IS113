<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= user.username %>'s Watchlist | MovieHub</title>
    <link rel="stylesheet" href="/watchlist.css">
    <link rel="stylesheet" href="/header.css">
</head>

<body>    
    <%- include("partials/header") %>

    <div class="back-row">
        <a href="javascript:history.back()" class="back-btn">← Back</a>
        <% if (watchlistMovies.length !== 0){ %>
            <div class="top-actions">
                <button type="button" class="clear-btn" onclick="toggleSelectMode()">Clear Selected</button>
                <form method="POST" action="/watchlist/clear">
                    <button type="submit" class="clear-btn">Clear All</button>
                </form>
            </div>
        <% } %>
    </div>

    <div class="page-content">
        
        <% if (watchlistMovies.length === 0) { %>
            <p class="empty">
            Your watchlist is empty.  
            Let's add some <a href="/movies">movies</a>!
            </p>
        <% } else { %>
            <form method="POST" action="/watchlist/clear-selected" id="clearSelectedForm">
                <table>
                    <% for (let i = 0; i < watchlistMovies.length; i += 5) { %>
                        <tr>
                            <% let cellsInRow = 0; %>

                            <% for (let j = i; j < i + 5 && j < watchlistMovies.length; j++) { %>
                                <td>
                                    <label class="select-box checkbox-hidden">
                                        <input type="checkbox" name="selectedIds" value="<%= watchlistMovies[j]._id %>">
                                        Select
                                    </label>                                    
                                    <a href="/details?id=<%= watchlistMovies[j].movieId %>">
                                        <img src="https://image.tmdb.org/t/p/w500<%= watchlistMovies[j].posterPath %>" 
                                            alt="<%= watchlistMovies[j].movieTitle %>">
                                    </a>

                                    <div class="movie-title">
                                        <a href="/details?id=<%= watchlistMovies[j].movieId %>">
                                            <%= watchlistMovies[j].movieTitle %>
                                        </a> <br>
                                        Added on: <%= (watchlistMovies[j].addedAt).toLocaleDateString("en-GB") %>
                                    </div>
                                </td>
                                <% cellsInRow++; %>
                            <% } %>

                            <% for (let k = cellsInRow; k < 5; k++) { %>
                                <td class="empty-cell"></td>
                            <% } %>
                        </tr>
                    <% } %>
                </table>
                <div class="bulk-actions checkbox-hidden" id="bulkActions">
                    <button type="submit" class="clear-btn">Delete Selected</button>
                    <button type="button" class="back-btn" onclick="toggleSelectMode()">Cancel</button>
                </div>
            </form>
        <% } %>
    </div>
</body>

<script>
    function toggleSelectMode() {
        const checkboxes = document.querySelectorAll(".checkbox-hidden");
        checkboxes.forEach(item => item.classList.toggle("show-checkbox"));
    }
</script>

</html>