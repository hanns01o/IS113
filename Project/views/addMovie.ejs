<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Add New Movie</title>
    <link rel="stylesheet" href="/header.css">
    <link rel="stylesheet" href="/addMovie.css">
</head>

<body>
    <%- include('partials/header') %>

        <main class="add-movie-page">
            <section class="add-movie-card">
                <h1>Add New Movie</h1>
                <p class="add-movie-subtitle">
                    Feel free add a new movie to our collection!
                </p>

                <% if (error) { %>
                    <div class="form-message error">
                        <%= error %>
                    </div>
                    <% } %>

                        <% if (success) { %>
                            <div class="form-message success">
                                <%= success %>
                            </div>
                            <% } %>

                                <form action="/movies/add" method="POST" class="add-movie-form">
                                    <div class="form-group">
                                        <label for="title">Movie Title:</label>
                                        <input type="text" id="title" name="title" required>
                                    </div>

                                    <label for="genre">Genre:</label>
                                    <div class="genre-container">
                                        <% genres.forEach(g=> { %>
                                            <label class="genre-tag">
                                                <input type="checkbox" name="genre" value="<%= g.id %>">
                                                <span>
                                                    <%= g.name %>
                                                </span>
                                            </label>
                                            <% }) %>
                                    </div>

                                    <div class="form-group">
                                        <label for="overview">Overview:</label>
                                        <textarea name="overview" rows="5" cols="50"
                                            required></textarea>
                                    </div>

                                    <div class="form-group">
                                        <label for="posterUrl">Poster URL:</label>
                                        <input type="text" id="posterUrl" name="posterUrl"
                                            placeholder="Paste poster image URL">
                                    </div>
                                    <div class="form-group">
                                        <label for="bannerUrl">Backdrop URL:</label>
                                        <input type="text" id="bannerUrl" name="bannerUrl"
                                            placeholder="Paste banner image URL">
                                    </div>
                                    </div>
                                    <button type="submit" class="submit-btn">Submit Movie</button>
                                </form>
            </section>
        </main>
</body>

</html>